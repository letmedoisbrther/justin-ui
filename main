                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDIM2_FILL,
                Font = Enum.Font.GothamBold, RichText = true,
                Text = KeyValue ~= Enum.KeyCode.Unknown and KeyValue.Name or "...",
                TextColor3 = WHITE, TextSize = 11,
                TextStrokeTransparency = 0.7
            })

            local ToggleBg = Library:Create("Frame", {
                Name = "Background", Parent = Right,
                BackgroundColor3 = DARK1, BorderColor3 = BLACK, BorderSizePixel = 0,
                LayoutOrder = -1,
                Size = UDim2.new(0, 20, 0, 20)
            })
            local ToggleStroke = MakeStroke(ToggleBg)
            MakeCorner(ToggleBg, UDim.new(0, 5))

            local Highlight = Library:Create("Frame", {
                Name = "Highligh", Parent = ToggleBg,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = PINK, BackgroundTransparency = 1,
                BorderColor3 = BLACK, BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(0, 20, 0, 20)
            })
            MakeCorner(Highlight, UDim.new(0, 5))
            MakeGradient(Highlight, GRAD_DARK)

            local CheckImg = Library:Create("ImageLabel", {
                Parent = Highlight,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderColor3 = BLACK, BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(0.45, 0, 0.45, 0),
                Image = "rbxassetid://86682186031062",
                ImageTransparency = 1
            })

            local Data = { Title = Args.Title, Desc = Args.Desc, Value = ToggleValue, Key = KeyValue }

            local function OnToggleChanged(val)
                Callback(val, Data.Key)
                if val then
                    TitleLbl.TextColor3 = PINK
                    ToggleStroke.Thickness = 0
                    Tween(Highlight, TI_05_EXP_OUT, { BackgroundTransparency = 0 })
                    Tween(CheckImg,  TI_05_EXP_OUT, { ImageTransparency = 0 })
                    Tween(CheckImg,  TI_03_EXP_OUT, { Size = UDim2.new(0.5, 0, 0.5, 0) })
                    Tween(KeyStroke, TI_02_EXP_OUT, { Color = PINK, Thickness = 1 })
                else
                    TitleLbl.TextColor3 = WHITE
                    ToggleStroke.Thickness = 0.5
                    Tween(Highlight, TI_05_EXP_OUT, { BackgroundTransparency = 1 })
                    Tween(CheckImg,  TI_05_EXP_OUT, { ImageTransparency = 1 })
                    Tween(KeyStroke, TI_02_EXP_OUT, { Color = STROKE2, Thickness = 1 })
                end
            end

            local ToggleClick = Library:MakeButton(ToggleBg)
            ToggleClick.MouseButton1Click:Connect(function()
                if Library:IsDropdownOpen() then return end
                Data.Value = not Data.Value
                OnToggleChanged(Data.Value)
            end)

            local listening = false
            local listenConn = nil

            local function StopListening()
                listening = false
                if listenConn then listenConn:Disconnect(); listenConn = nil end
                Tween(KeyBtn, TI_02_EXP_OUT, { BackgroundColor3 = DARK1 })
            end

            local KeyClick = Library:MakeButton(KeyBtn)
            KeyClick.MouseButton1Click:Connect(function()
                if Library:IsDropdownOpen() then return end
                if listening then StopListening(); return end
                listening = true
                KeyLabel.Text = "..."
                Tween(KeyBtn, TI_02_EXP_OUT, { BackgroundColor3 = Color3.fromRGB(40, 10, 25) })

                listenConn = UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        Data.Key = input.KeyCode
                        KeyLabel.Text = Data.Key.Name
                        StopListening()
                    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                        StopListening()
                    end
                end)
            end)

            UserInputService.InputBegan:Connect(function(input, processed)
                if processed then return end
                if listening then return end
                if Data.Value and Data.Key ~= Enum.KeyCode.Unknown and input.KeyCode == Data.Key then
                    Callback(true, Data.Key)
                end
            end)

            if Data.Value then OnToggleChanged(true) end

            if Args.Flag then
                Window.Flags[Args.Flag] = {
                    Type = "KeybindToggle",
                    GetValue = function() return Data.Value, Data.Key end,
                    SetValue = function(v, key)
                        Data.Value = v
                        if key then
                            Data.Key = key
                            KeyLabel.Text = key ~= Enum.KeyCode.Unknown and key.Name or "..."
                        end
                        OnToggleChanged(v)
                    end
                }
            end

            local Setting = setmetatable({}, {
                __newindex = function(t, k, v)
                    rawset(Data, k, v)
                    if k == "Title" then Left.Title.Text = tostring(v)
                    elseif k == "Desc" then Left.Desc.Text = tostring(v)
                    elseif k == "Value" then Data.Value = v; OnToggleChanged(v)
                    elseif k == "Key" then
                        Data.Key = v
                        KeyLabel.Text = v ~= Enum.KeyCode.Unknown and v.Name or "..."
                    end
                end,
                __index = Data
            })

            return Setting
        end

        function Page:ColorToggle(Args)
            local ToggleValue = Args.Value or false
            local ColorValue  = Args.Color or Color3.fromRGB(255, 0, 127)
            local Callback    = Args.Callback or function() end

            local Rows  = Library:NewRows(PageScrolling, Args.Title, Args.Desc)
            local Right = Rows.Vectorize.Right
            local Left  = Rows.Vectorize.Left.Text
            local TitleLbl = Left.Title

            local Preview = Library:Create("Frame", {
                Name = "Preview", Parent = Right,
                BackgroundColor3 = ColorValue, BorderSizePixel = 0,
                LayoutOrder = -2,
                Size = UDim2.new(0, 30, 0, 22)
            })
            MakeCorner(Preview, UDim.new(0, 6))
            MakeStroke(Preview, STROKE2, 1)

            local ToggleBg = Library:Create("Frame", {
                Name = "Background", Parent = Right,
                BackgroundColor3 = DARK1, BorderColor3 = BLACK, BorderSizePixel = 0,
                LayoutOrder = -1,
                Size = UDim2.new(0, 20, 0, 20)
            })
            local ToggleStroke = MakeStroke(ToggleBg)
            MakeCorner(ToggleBg, UDim.new(0, 5))

            local Highlight = Library:Create("Frame", {
                Name = "Highligh", Parent = ToggleBg,
                AnchorPoint = ANCHOR_CENTER,
