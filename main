    local PageService = Library:Create("UIPageLayout", { Parent = Scale })

    local Window = {}
    Window.Flags = {}

    local configDir = "Library"
    local configSubDir = configDir .. "/" .. Title:gsub("[^%w]", "_")

    local function ensureConfigDir()
        pcall(function()
            if not isfolder(configDir) then makefolder(configDir) end
            if not isfolder(configSubDir) then makefolder(configSubDir) end
        end)
    end

    function Window:SaveConfig(name)
        if not name or name == "" then return false end
        ensureConfigDir()
        local data = {}
        for flag, info in pairs(Window.Flags) do
            local entry = { Flag = flag, Type = info.Type }
            if info.Type == "ColorPicker" or info.Type == "ColorToggle" then
                local vals = info.GetValue()
                local col, extra = vals[1], vals[2]
                entry.Value = { R = col.R, G = col.G, B = col.B }
                if info.Type == "ColorToggle" then entry.Extra = extra end
            elseif info.Type == "Keybind" then
                local val = info.GetValue()
                entry.Value = typeof(val) == "EnumItem" and val.Name or tostring(val)
            elseif info.Type == "KeybindToggle" then
                local val, key = info.GetValue()
                entry.Value = val
                entry.Extra = typeof(key) == "EnumItem" and key.Name or tostring(key)
            else
                entry.Value = info.GetValue()
            end
            table.insert(data, entry)
        end
        local ok = pcall(function()
            writefile(configSubDir .. "/" .. name .. ".json", HttpService:JSONEncode(data))
        end)
        return ok
    end

    function Window:LoadConfig(name)
        local path = configSubDir .. "/" .. name .. ".json"
        local ok, content = pcall(readfile, path)
        if not ok or not content then return false end
        local ok2, data = pcall(function() return HttpService:JSONDecode(content) end)
        if not ok2 or not data then return false end
        for _, entry in ipairs(data) do
            local info = Window.Flags[entry.Flag]
            if info and entry.Value ~= nil then
                if entry.Type == "ColorPicker" then
                    local v = entry.Value
                    info.SetValue(Color3.new(v.R, v.G, v.B))
                elseif entry.Type == "ColorToggle" then
                    local v = entry.Value
                    info.SetValue(entry.Extra, Color3.new(v.R, v.G, v.B))
                elseif entry.Type == "Keybind" then
                    local key = Enum.KeyCode[entry.Value]
                    if key then info.SetValue(key) end
                elseif entry.Type == "KeybindToggle" then
                    local key = Enum.KeyCode[entry.Extra]
                    info.SetValue(entry.Value, key)
                else
                    info.SetValue(entry.Value)
                end
            end
        end
        return true
    end

    function Window:GetConfigList()
        local list = {}
        pcall(function()
            ensureConfigDir()
            for _, path in ipairs(listfiles(configSubDir)) do
                local name = path:match("([^/\\]+)%.json$")
                if name then table.insert(list, name) end
            end
        end)
        return list
    end

    function Window:DeleteConfig(name)
        pcall(delfile, configSubDir .. "/" .. name .. ".json")
    end

