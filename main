    end

    task.defer(function()
        local ConfigsPage = Window:NewPage({
            Title = "Configs",
            Desc  = "Salvar e carregar configurações",
            Icon  = "settings"
        })

        ConfigsPage:Section("Salvar Config")

        local configNameValue = ""
        ConfigsPage:Input({
            Value = "",
            Callback = function(text)
                configNameValue = text
            end
        })

        local ConfigsListContainer

        local function RefreshConfigsList()
            if not ConfigsListContainer then return end
            for _, child in ipairs(ConfigsListContainer:GetChildren()) do
                if child.Name == "Rows" then child:Destroy() end
            end

            local list = Window:GetConfigList()
            if #list == 0 then
                Library:Create("TextLabel", {
                    Name = "Rows", Parent = ConfigsListContainer,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 0, 20),
                    Font = Enum.Font.GothamMedium, Text = "Nenhum config salvo.",
                    TextColor3 = GRAY2, TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                return
            end

            for _, cfgName in ipairs(list) do
                local Rows = Library:NewRows(ConfigsListContainer, cfgName, "")
                local Right = Rows.Vectorize.Right

                local LoadBtnFrame = Library:Create("Frame", {
                    Name = "LoadBtn", Parent = Right,
                    BackgroundColor3 = PINK, BorderSizePixel = 0,
                    Size = UDim2.new(0, 68, 0, 24)
                })
                MakeCorner(LoadBtnFrame)
                MakeGradient(LoadBtnFrame, GRAD_DARK)

                Library:Create("TextLabel", {
                    Parent = LoadBtnFrame,
                    AnchorPoint = ANCHOR_CENTER,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    Size = UDIM2_FILL,
                    Font = Enum.Font.GothamSemibold,
                    Text = "Carregar",
                    TextColor3 = WHITE, TextSize = 10
                })

                local LoadClick = Library:MakeButton(LoadBtnFrame)
                LoadClick.MouseButton1Click:Connect(function()
                    local ok = Window:LoadConfig(cfgName)
                    Library:Notify({
                        Title = ok and "Config carregado" or "Erro",
                        Desc  = ok and ("\"" .. cfgName .. "\" carregado com sucesso.") or "Falha ao carregar o config.",
                        Duration = 3
                    })
                end)

                local DelBtnFrame = Library:Create("Frame", {
                    Name = "DelBtn", Parent = Right,
                    BackgroundColor3 = Color3.fromRGB(40, 10, 16), BorderSizePixel = 0,
                    Size = UDim2.new(0, 28, 0, 24)
                })
                MakeCorner(DelBtnFrame)
                MakeStroke(DelBtnFrame, STROKE3, 1)

                Library:Create("TextLabel", {
                    Parent = DelBtnFrame,
                    AnchorPoint = ANCHOR_CENTER,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    Size = UDIM2_FILL,
                    Font = Enum.Font.GothamBold,
                    Text = "×",
                    TextColor3 = PINK, TextSize = 14
                })

                local DelClick = Library:MakeButton(DelBtnFrame)
                DelClick.MouseButton1Click:Connect(function()
                    Window:DeleteConfig(cfgName)
                    Library:Notify({
                        Title = "Config deletado",
                        Desc  = "\"" .. cfgName .. "\" foi removido.",
                        Duration = 3
                    })
                    RefreshConfigsList()
                end)
            end
        end

        ConfigsPage:Button({
            Title = "Salvar configuração atual",
            Desc  = "Digite um nome no campo acima e clique para salvar",
            Text  = "Salvar",
            Callback = function()
                if not configNameValue or configNameValue == "" then
                    Library:Notify({
                        Title = "Configs",
                        Desc  = "Digite um nome para o config.",
                        Duration = 3
                    })
                    return
                end
                local ok = Window:SaveConfig(configNameValue)
                Library:Notify({
                    Title = ok and "Config salvo" or "Erro",
                    Desc  = ok and ("\"" .. configNameValue .. "\" foi salvo.") or "Falha ao salvar o config.",
                    Duration = 3
                })
                RefreshConfigsList()
            end
        })

        ConfigsPage:Separator()
        ConfigsPage:Section("Configs Salvos")

        ConfigsListContainer = Library:Create("Frame", {
            Name = "ConfigsListContainer", Parent = ConfigsPage.PageScrolling,
            BackgroundColor3 = WHITE, BackgroundTransparency = 1,
            BorderSizePixel = 0,
            AutomaticSize = Enum.AutomaticSize.Y,
            Size = UDim2.new(1, 0, 0, 0)
        })
        Library:Create("UIListLayout", {
            Parent = ConfigsListContainer,
            Padding = UDim.new(0, 5),
            SortOrder = Enum.SortOrder.LayoutOrder
        })

        RefreshConfigsList()
    end)

    return Window
end

return Library
