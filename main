                if val then
                    TitleLbl.TextColor3 = PINK
                    ToggleStroke.Thickness = 0
                    Tween(Highlight, TI_05_EXP_OUT, { BackgroundTransparency = 0 })
                    Tween(CheckImg,  TI_05_EXP_OUT, { ImageTransparency = 0 })
                    Tween(CheckImg,  TI_03_EXP_OUT, { Size = UDim2.new(0.5, 0, 0.5, 0) })
                else
                    TitleLbl.TextColor3 = WHITE
                    ToggleStroke.Thickness = 0.5
                    Tween(Highlight, TI_05_EXP_OUT, { BackgroundTransparency = 1 })
                    Tween(CheckImg,  TI_05_EXP_OUT, { ImageTransparency = 1 })
                end
            end

            local ToggleClick = Library:MakeButton(ToggleBg)
            ToggleClick.MouseButton1Click:Connect(function()
                if Library:IsDropdownOpen() then return end
                Data.Value = not Data.Value
                OnToggleChanged(Data.Value)
            end)

            local OpenBtn = Library:MakeButton(Preview)

            local Picker = Library:Create("Frame", {
                Name = "ColorPicker", Parent = Background,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = DARK4, BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.3, 0),
                Size = UDim2.new(0, 240, 0, 280),
                ZIndex = 500, Selectable = false, Visible = false
            })
            MakeCorner(Picker)
            MakeStroke(Picker, STROKE2)
            table.insert(dropdownInstances, Picker)

            Library:Create("UIListLayout", {
                Parent = Picker,
                Padding = UDim.new(0, 8),
                SortOrder = Enum.SortOrder.LayoutOrder,
                HorizontalAlignment = Enum.HorizontalAlignment.Center
            })
            Library:Create("UIPadding", {
                Parent = Picker,
                PaddingBottom = UDim.new(0, 12), PaddingLeft = UDim.new(0, 12),
                PaddingRight = UDim.new(0, 12), PaddingTop = UDim.new(0, 12)
            })

            local PickerTitle = Library:Create("TextLabel", {
                Name = "Title", Parent = Picker,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0, LayoutOrder = -5,
                Size = UDim2.new(1, 0, 0, 14),
                ZIndex = 500,
                Font = Enum.Font.GothamSemibold, RichText = true,
                Text = Args.Title or "Color",
                TextColor3 = PINK, TextSize = 14,
                TextStrokeTransparency = 0.7,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            MakeGradient(PickerTitle, GRAD_WHITE)

            local SatVal = Library:Create("Frame", {
                Name = "SatVal", Parent = Picker,
                BackgroundColor3 = Color3.fromHSV(0, 1, 1), BorderSizePixel = 0,
                LayoutOrder = -4,
                Size = UDim2.new(1, 0, 0, 140),
                ZIndex = 500, ClipsDescendants = true, Selectable = false
            })
            MakeCorner(SatVal, UDim.new(0, 5))

            local WhiteGrad = Library:Create("Frame", {
                Name = "WhiteGrad", Parent = SatVal,
                BackgroundColor3 = WHITE, BorderSizePixel = 0,
                Size = UDIM2_FILL, ZIndex = 500
            })
            MakeGradient(WhiteGrad, ColorSequence.new{
                ColorSequenceKeypoint.new(0, WHITE),
                ColorSequenceKeypoint.new(1, WHITE)
            }, 0)
            WhiteGrad.UIGradient.Transparency = NumberSequence.new{
                NumberSequenceKeypoint.new(0, 0),
                NumberSequenceKeypoint.new(1, 1)
            }

            local BlackGrad = Library:Create("Frame", {
                Name = "BlackGrad", Parent = SatVal,
                BackgroundColor3 = BLACK, BorderSizePixel = 0,
                Size = UDIM2_FILL, ZIndex = 500
            })
            MakeGradient(BlackGrad, ColorSequence.new{
                ColorSequenceKeypoint.new(0, BLACK),
                ColorSequenceKeypoint.new(1, BLACK)
            }, 90)
            BlackGrad.UIGradient.Transparency = NumberSequence.new{
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(1, 0)
            }

            local SVCursor = Library:Create("Frame", {
                Name = "Cursor", Parent = SatVal,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BorderSizePixel = 0,
                Position = UDim2.new(1, 0, 0, 0),
                Size = UDim2.new(0, 10, 0, 10),
                ZIndex = 502, Selectable = false
            })
            MakeCorner(SVCursor, UDim.new(1, 0))
            MakeStroke(SVCursor, BLACK, 1.5)

            local SVClick = Library:MakeButton(SatVal)

            local HueBar = Library:Create("Frame", {
                Name = "Hue", Parent = Picker,
                BackgroundColor3 = WHITE, BorderSizePixel = 0,
                LayoutOrder = -3,
                Size = UDim2.new(1, 0, 0, 16),
                ZIndex = 500, Selectable = false
            })
            MakeCorner(HueBar, UDim.new(0, 5))
            Library:Create("UIGradient", {
                Parent = HueBar,
                Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0.000, Color3.fromHSV(0/6, 1, 1)),
                    ColorSequenceKeypoint.new(0.166, Color3.fromHSV(1/6, 1, 1)),
                    ColorSequenceKeypoint.new(0.333, Color3.fromHSV(2/6, 1, 1)),
                    ColorSequenceKeypoint.new(0.500, Color3.fromHSV(3/6, 1, 1)),
                    ColorSequenceKeypoint.new(0.666, Color3.fromHSV(4/6, 1, 1)),
                    ColorSequenceKeypoint.new(0.833, Color3.fromHSV(5/6, 1, 1)),
                    ColorSequenceKeypoint.new(1.000, Color3.fromHSV(6/6, 1, 1))
                },
                Rotation = 0
            })

            local HueCursor = Library:Create("Frame", {
                Name = "Cursor", Parent = HueBar,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BorderSizePixel = 0,
                Position = UDim2.new(0, 0, 0.5, 0),
                Size = UDim2.new(0, 6, 1, 6),
                ZIndex = 502, Selectable = false
            })
            MakeCorner(HueCursor, UDim.new(0, 3))
            MakeStroke(HueCursor, BLACK, 1.5)

            local HueClick = Library:MakeButton(HueBar)

            local RGBRow = Library:Create("Frame", {
                Name = "RGB", Parent = Picker,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0, LayoutOrder = -2,
                Size = UDim2.new(1, 0, 0, 30),
                ZIndex = 500
            })
            Library:Create("UIListLayout", {
                Parent = RGBRow,
                Padding = UDim.new(0, 6),
                FillDirection = Enum.FillDirection.Horizontal,
                SortOrder = Enum.SortOrder.LayoutOrder
            })

            local function MakeRGBBox(label)
                local Box = Library:Create("Frame", {
                    Name = label, Parent = RGBRow,
                    BackgroundColor3 = DARK3, BorderSizePixel = 0,
                    Size = UDim2.new(0, 64, 1, 0),
                    ZIndex = 500
                })
                MakeCorner(Box, UDim.new(0, 4))
                MakeStroke(Box)

                Library:Create("TextLabel", {
                    Name = "Tag", Parent = Box,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 6, 0, 2),
                    Size = UDim2.new(0, 20, 0, 10),
                    ZIndex = 501,
                    Font = Enum.Font.GothamBold, Text = label,
                    TextColor3 = PINK, TextSize = 9,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                local Box_Input = Library:Create("TextBox", {
                    Name = "Input", Parent = Box,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 6, 0, 12),
                    Size = UDim2.new(1, -12, 0, 14),
                    ZIndex = 501,
                    Font = Enum.Font.GothamMedium,
                    Text = "0", TextColor3 = WHITE, TextSize = 11,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                return Box_Input
            end

            local RBox = MakeRGBBox("R")
            local GBox = MakeRGBBox("G")
            local BBox = MakeRGBBox("B")

            local Hue, Sat, Val = Color3.toHSV(Data.Color)

            local function UpdateFromHSV(skipBoxes)
                local color = Color3.fromHSV(Hue, Sat, Val)
                Data.Color = color
                Preview.BackgroundColor3 = color
                SatVal.BackgroundColor3 = Color3.fromHSV(Hue, 1, 1)
                SVCursor.Position = UDim2.new(Sat, 0, 1 - Val, 0)
                HueCursor.Position = UDim2.new(Hue, 0, 0.5, 0)
                if not skipBoxes then
                    RBox.Text = tostring(math.floor(color.R * 255 + 0.5))
                    GBox.Text = tostring(math.floor(color.G * 255 + 0.5))
                    BBox.Text = tostring(math.floor(color.B * 255 + 0.5))
                end
                Callback(Data.Value, color)
            end

            local draggingSV, draggingHue = false, false

            SVClick.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    draggingSV = true
                end
            end)
            SVClick.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    draggingSV = false
                end
            end)

            HueClick.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    draggingHue = true
                end
            end)
            HueClick.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    draggingHue = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
                if draggingSV then
                    local rx = math.clamp((input.Position.X - SatVal.AbsolutePosition.X) / SatVal.AbsoluteSize.X, 0, 1)
                    local ry = math.clamp((input.Position.Y - SatVal.AbsolutePosition.Y) / SatVal.AbsoluteSize.Y, 0, 1)
                    Sat = rx
                    Val = 1 - ry
                    UpdateFromHSV()
                elseif draggingHue then
                    local rx = math.clamp((input.Position.X - HueBar.AbsolutePosition.X) / HueBar.AbsoluteSize.X, 0, 1)
                    Hue = rx
                    UpdateFromHSV()
                end
            end)

            local function CommitRGB()
                local r = math.clamp(tonumber(RBox.Text) or 0, 0, 255)
                local g = math.clamp(tonumber(GBox.Text) or 0, 0, 255)
                local b = math.clamp(tonumber(BBox.Text) or 0, 0, 255)
                local color = Color3.fromRGB(r, g, b)
                Hue, Sat, Val = Color3.toHSV(color)
                UpdateFromHSV(true)
            end

            RBox.FocusLost:Connect(CommitRGB)
            GBox.FocusLost:Connect(CommitRGB)
            BBox.FocusLost:Connect(CommitRGB)

            local isOpen = false

            UserInputService.InputBegan:Connect(function(A)
                if not isOpen then return end
                if A.UserInputType ~= Enum.UserInputType.MouseButton1 and A.UserInputType ~= Enum.UserInputType.Touch then return end
                local mouse = LocalPlayer:GetMouse()
                local PBP, PBS = Picker.AbsolutePosition, Picker.AbsoluteSize
                if not (mouse.X >= PBP.X and mouse.X <= PBP.X + PBS.X and mouse.Y >= PBP.Y and mouse.Y <= PBP.Y + PBS.Y) then
                    isOpen = false
                    Picker.Visible = false
                    Picker.Position = UDim2.new(0.5, 0, 0.3, 0)
                end
            end)

            OpenBtn.MouseButton1Click:Connect(function()
                if Library:IsDropdownOpen() and not isOpen then return end
                isOpen = not isOpen
                if isOpen then
                    Picker.Visible = true
                    Tween(Picker, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Position = UDim2.new(0.5, 0, 0.5, 0) })
                else
                    Picker.Visible = false
                    Picker.Position = UDim2.new(0.5, 0, 0.3, 0)
                end
            end)

            UpdateFromHSV()
            if Data.Value then OnToggleChanged(true) end

            if Args.Flag then
                Window.Flags[Args.Flag] = {
                    Type = "ColorToggle",
                    GetValue = function() return { Data.Color, Data.Value } end,
                    SetValue = function(val, color)
                        Data.Value = val
                        if color then
                            Hue, Sat, Val = Color3.toHSV(color)
                            UpdateFromHSV()
                        end
                        OnToggleChanged(val)
                    end
                }
            end

            local Setting = setmetatable({}, {
                __newindex = function(t, k, v)
                    rawset(Data, k, v)
                    if k == "Title" then Left.Title.Text = tostring(v)
                    elseif k == "Desc" then Left.Desc.Text = tostring(v)
                    elseif k == "Value" then Data.Value = v; OnToggleChanged(v)
                    elseif k == "Color" then
                        Hue, Sat, Val = Color3.toHSV(v)
                        UpdateFromHSV()
                    end
                end,
                __index = Data
            })

            return Setting
        end

        function Page:Slider(Args)
            local Min      = Args.Min
            local Max      = Args.Max
            local Rounding = Args.Rounding or 0
            local Value    = Args.Value or Min
            local Callback = Args.Callback or function() end

            local Slider = Library:Create("Frame", {
                Name = "Slider", Parent = PageScrolling,
                BackgroundColor3 = DARK3, BackgroundTransparency = 0,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 42),
                Selectable = false
            })
            MakeCorner(Slider)
            MakeStroke(Slider)
            Library:Create("UIPadding", {
                Parent = Slider,
                PaddingBottom = UDim.new(0, 1),
                PaddingLeft = UDim.new(0, 10),
                PaddingRight = UDim.new(0, 10)
            })

            local TextFrame = Library:Create("Frame", {
                Name = "Text", Parent = Slider,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 0, 0.1, 0),
                Size = UDim2.new(0, 111, 0, 22),
                Selectable = false
            })
            Library:Create("UIListLayout", {
                Parent = TextFrame,
                SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Center
            })
            Library:Create("UIPadding", { Parent = TextFrame, PaddingBottom = UDim.new(0, 3) })

            local SliderTitle = Library:Create("TextLabel", {
                Name = "Title", Parent = TextFrame,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0, LayoutOrder = -1,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(1, 0, 0, 13),
                Selectable = false,
                Font = Enum.Font.GothamSemibold, RichText = true,
                Text = Args.Title,
                TextColor3 = WHITE, TextSize = 12,
                TextStrokeTransparency = 0.7,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            MakeGradient(SliderTitle, GRAD_WHITE)

            local Scaling = Library:Create("Frame", {
                Name = "Scaling", Parent = Slider,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0, Size = UDIM2_FILL, Selectable = false
            })

            local Slide = Library:Create("Frame", {
                Name = "Slide", Parent = Scaling,
                AnchorPoint = Vector2.new(0, 1),
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 0, 1, 0),
                Size = UDim2.new(1, 0, 0, 23),
                Selectable = false
            })

            local TrackBar = Library:Create("Frame", {
                Name = "ColorBar", Parent = Slide,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = DARK1, BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(1, 0, 0, 5),
                Selectable = false
            })
            MakeCorner(TrackBar)

            local FillBar = Library:Create("Frame", {
                Name = "ColorBar", Parent = TrackBar,
                BackgroundColor3 = PINK, BorderSizePixel = 0,
                Size = UDIM2_ZERO, Selectable = false
            })
            MakeCorner(FillBar)
            MakeGradient(FillBar, GRAD_SLIDER)

            Library:Create("Frame", {
                Name = "Circle", Parent = FillBar,
                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundColor3 = WHITE, BorderSizePixel = 0,
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 5, 0, 11),
                Selectable = false
            })

            local ValueBox = Library:Create("TextBox", {
                Name = "Boxvalue", Parent = Scaling,
                AnchorPoint = Vector2.new(1, 0.5),
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.new(1, -5, 0.449, -2),
                Size = UDim2.new(0, 60, 0, 15),
                ZIndex = 5,
                Font = Enum.Font.GothamMedium,
                PlaceholderColor3 = Color3.fromRGB(178, 178, 178),
                Text = tostring(Value),
                TextColor3 = WHITE, TextSize = 11,
                TextTransparency = 0.5,
                TextTruncate = Enum.TextTruncate.AtEnd,
                TextXAlignment = Enum.TextXAlignment.Right
            })

            local dragging = false

            local function Round(n, d)
                local f = 10 ^ d
                return math.floor(n * f + 0.5) / f
            end

            local function UpdateSlider(val)
                val = Round(math.clamp(val, Min, Max), Rounding)
                local ratio = (val - Min) / (Max - Min)
                Tween(FillBar, TI_01_LIN_OUT, { Size = UDim2.new(ratio, 0, 1, 0) })
                ValueBox.Text = tostring(val)
                Callback(val)
                return val
            end

            local function GetValueFromInput(input)
                local ratio = math.clamp((input.Position.X - TrackBar.AbsolutePosition.X) / TrackBar.AbsoluteSize.X, 0, 1)
                return ratio * (Max - Min) + Min
            end

            local function SetDragging(state)
                dragging = state
                if state then
                    Tween(ValueBox,    TI_03_BACK_OUT, { TextSize = 15 })
                    Tween(ValueBox,    TI_02_EXP_OUT,  { TextColor3 = PINK })
                    Tween(SliderTitle, TI_02_EXP_OUT,  { TextColor3 = PINK })
                else
                    Tween(ValueBox,    TI_03_BACK_OUT, { TextSize = 11 })
                    Tween(ValueBox,    TI_02_EXP_OUT,  { TextColor3 = WHITE })
                    Tween(SliderTitle, TI_02_EXP_OUT,  { TextColor3 = WHITE })
                end
            end

            local SliderClick = Library:MakeButton(Slider)

            SliderClick.InputBegan:Connect(function(input)
                if Library:IsDropdownOpen() then return end
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    SetDragging(true)
                    UpdateSlider(GetValueFromInput(input))
                end
            end)

            SliderClick.InputEnded:Connect(function(input)
                if Library:IsDropdownOpen() then return end
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    SetDragging(false)
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if Library:IsDropdownOpen() then return end
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(GetValueFromInput(input))
                end
            end)

            ValueBox.Focused:Connect(function()
                Tween(ValueBox,    TI_02_EXP_OUT, { TextColor3 = PINK })
                Tween(SliderTitle, TI_02_EXP_OUT, { TextColor3 = PINK })
            end)

            ValueBox.FocusLost:Connect(function()
                Tween(ValueBox,    TI_02_EXP_OUT, { TextColor3 = WHITE })
                Tween(SliderTitle, TI_02_EXP_OUT, { TextColor3 = WHITE })
                Value = UpdateSlider(tonumber(ValueBox.Text) or Value)
            end)

            UpdateSlider(Value)

            if Args.Flag then
                Window.Flags[Args.Flag] = {
                    Type = "Slider",
                    GetValue = function() return Value end,
                    SetValue = function(v) Value = UpdateSlider(v) end
                }
            end

            return {
                SetValue = function(self, v) Value = UpdateSlider(v) end,
                GetValue = function(self) return Value end
            }
        end

        function Page:Input(Args)
            local Value    = Args.Value or ""
            local Callback = Args.Callback or function() end

            local InputFrame = Library:Create("Frame", {
                Name = "Input", Parent = PageScrolling,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 30),
                Selectable = false
            })
            Library:Create("UIListLayout", {
                Parent = InputFrame,
                Padding = UDim.new(0, 5),
                FillDirection = Enum.FillDirection.Horizontal,
                SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Center
            })

            local Front = Library:Create("Frame", {
                Name = "Front", Parent = InputFrame,
                BackgroundColor3 = DARK3, BorderSizePixel = 0,
                Size = UDim2.new(1, -35, 1, 0),
                Selectable = false
            })
            MakeCorner(Front, UDim.new(0, 2))
            MakeStroke(Front)

            local TextBox = Library:Create("TextBox", {
                Parent = Front,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(1, -20, 1, 0),
                Font = Enum.Font.GothamMedium,
                PlaceholderColor3 = Color3.fromRGB(55, 55, 55),
                PlaceholderText = "Paste your text input here.",
                Text = tostring(Value),
                TextColor3 = GRAY2, TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local EnterBtn = Library:Create("Frame", {
                Name = "Enter", Parent = InputFrame,
                BackgroundColor3 = PINK, BorderSizePixel = 0,
                Size = UDim2.new(0, 30, 0, 30),
                Selectable = false
            })
            MakeCorner(EnterBtn)
            MakeGradient(EnterBtn, GRAD_DARK)

            local EnterIcon = Library:Create("ImageLabel", {
                Name = "Asset", Parent = EnterBtn,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(0, 15, 0, 15),
                Image = "rbxassetid://78020815235467"
            })

            local CopyClick = Library:MakeButton(EnterBtn)

            TextBox.FocusLost:Connect(function(enterPressed)
                if enterPressed and TextBox.Text ~= "" then
                    Callback(TextBox.Text)
                end
            end)

            CopyClick.MouseButton1Click:Connect(function()
                if Library:IsDropdownOpen() then return end
                pcall(setclipboard, Value)
                EnterIcon.Image = "rbxassetid://121742282171603"
                task.delay(3, function()
                    EnterIcon.Image = "rbxassetid://78020815235467"
                end)
            end)

            if Args.Flag then
                Window.Flags[Args.Flag] = {
                    Type = "Input",
                    GetValue = function() return TextBox.Text end,
                    SetValue = function(v)
                        TextBox.Text = tostring(v)
                        Value = TextBox.Text
                        Callback(TextBox.Text)
                    end
                }
            end

            return TextBox
        end

        function Page:Dropdown(Args)
            local List    = Args.List
            local Value   = Args.Value
            local Callback = Args.Callback
            local IsMulti = type(Value) == "table"

            local Rows  = Library:NewRows(PageScrolling, Args.Title, "N/A")
            local Right = Rows.Vectorize.Right
            local Left  = Rows.Vectorize.Left.Text

            Library:Create("ImageLabel", {
                Parent = Right,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderColor3 = BLACK, BorderSizePixel = 0,
                Size = UDim2.new(0, 20, 0, 20),
                Image = "rbxassetid://132291592681506",
                ImageTransparency = 0.5
            })

            local OpenBtn = Library:MakeButton(Rows.Vectorize)

            local function GetText()
                if IsMulti then return table.concat(Value, ", ") end
                return tostring(Value)
            end
            Left.Desc.Text = GetText()

            local Dropdown = Library:Create("Frame", {
                Name = "Dropdown", Parent = Background,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = DARK4, BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.3, 0),
                Size = UDim2.new(0, 300, 0, 250),
                ZIndex = 500, Selectable = false, Visible = false
            })
            MakeCorner(Dropdown)
            MakeStroke(Dropdown, STROKE2)
            table.insert(dropdownInstances, Dropdown)

            Library:Create("UIListLayout", {
                Parent = Dropdown,
                Padding = UDim.new(0, 5),
                SortOrder = Enum.SortOrder.LayoutOrder,
                HorizontalAlignment = Enum.HorizontalAlignment.Center
            })
            Library:Create("UIPadding", {
                Parent = Dropdown,
                PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 10),
                PaddingRight = UDim.new(0, 10), PaddingTop = UDim.new(0, 10)
            })

            local DDText = Library:Create("Frame", {
                Name = "Text", Parent = Dropdown,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0, LayoutOrder = -5,
                Size = UDim2.new(1, 0, 0, 30),
                ZIndex = 500, Selectable = false
            })
            Library:Create("UIListLayout", {
                Parent = DDText,
                Padding = UDim.new(0, 1),
                SortOrder = Enum.SortOrder.LayoutOrder,
                HorizontalAlignment = Enum.HorizontalAlignment.Center,
                VerticalAlignment = Enum.VerticalAlignment.Center
            })

            local DDTitle = Library:Create("TextLabel", {
                Name = "Title", Parent = DDText,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0, LayoutOrder = -1,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(1, 0, 0, 13),
                ZIndex = 500, Selectable = false,
                Font = Enum.Font.GothamSemibold, RichText = true,
                Text = Args.Title,
                TextColor3 = PINK, TextSize = 14,
                TextStrokeTransparency = 0.7,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            MakeGradient(DDTitle, GRAD_WHITE)

            local DDDesc = Library:Create("TextLabel", {
                Name = "Desc", Parent = DDText,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(1, 0, 0, 10),
                ZIndex = 500, Selectable = false,
                Font = Enum.Font.GothamMedium, RichText = true,
                Text = GetText(),
                TextColor3 = WHITE, TextSize = 10,
                TextStrokeTransparency = 0.7, TextTransparency = 0.6,
                TextTruncate = Enum.TextTruncate.AtEnd,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local DDInput = Library:Create("Frame", {
                Name = "Input", Parent = Dropdown,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0, LayoutOrder = -4,
                Size = UDim2.new(1, 0, 0, 25),
                ZIndex = 500, Selectable = false
            })
            Library:Create("UIListLayout", {
                Parent = DDInput,
                Padding = UDim.new(0, 5),
                FillDirection = Enum.FillDirection.Horizontal,
                SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Center
            })

            local DDFront = Library:Create("Frame", {
                Name = "Front", Parent = DDInput,
                BackgroundColor3 = DARK3, BorderSizePixel = 0,
                Size = UDIM2_FILL,
                ZIndex = 500, Selectable = false
            })
            MakeCorner(DDFront, UDim.new(0, 2))
            MakeStroke(DDFront)

            local SearchBox = Library:Create("TextBox", {
                Name = "Search", Parent = DDFront,
                AnchorPoint = ANCHOR_CENTER,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0, CursorPosition = -1,
                Position = UDim2.new(0.5, 0, 0.5, 0),
                Size = UDim2.new(1, -20, 1, 0),
                ZIndex = 500,
                Font = Enum.Font.GothamMedium,
                PlaceholderColor3 = Color3.fromRGB(55, 55, 55),
                PlaceholderText = "Search",
                Text = "",
                TextColor3 = WHITE, TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local ListFrame = Library:Create("ScrollingFrame", {
                Name = "List", Parent = Dropdown,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 160),
                ZIndex = 500, ScrollBarThickness = 0
            })
            local ListLayout = Library:Create("UIListLayout", {
                Parent = ListFrame,
                Padding = UDim.new(0, 3),
                SortOrder = Enum.SortOrder.LayoutOrder,
                HorizontalAlignment = Enum.HorizontalAlignment.Center
            })
            Library:Create("UIPadding", {
                Parent = ListFrame,
                PaddingLeft = UDim.new(0, 1), PaddingRight = UDim.new(0, 1)
            })

            ListLayout:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(function()
                ListFrame.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 15)
            end)

            local selectedValues = {}
            local selectedOrder  = 0

            local function isInTable(val, tbl)
                if type(tbl) ~= "table" then return false end
                for _, v in tbl do
                    if v == val then return true end
                end
                return false
            end

            local function Settext()
                local txt = IsMulti and table.concat(Value, ", ") or tostring(Value)
                DDDesc.Text    = txt
                Left.Desc.Text = txt
            end

            local isOpen = false

            UserInputService.InputBegan:Connect(function(A)
                if not isOpen then return end
                if A.UserInputType ~= Enum.UserInputType.MouseButton1 and A.UserInputType ~= Enum.UserInputType.Touch then return end
                local mouse = LocalPlayer:GetMouse()
                local DBP, DBS = Dropdown.AbsolutePosition, Dropdown.AbsoluteSize
                if not (mouse.X >= DBP.X and mouse.X <= DBP.X + DBS.X and mouse.Y >= DBP.Y and mouse.Y <= DBP.Y + DBS.Y) then
                    isOpen = false
                    Dropdown.Visible = false
                    Dropdown.Position = UDim2.new(0.5, 0, 0.3, 0)
                end
            end)

            OpenBtn.MouseButton1Click:Connect(function()
                if Library:IsDropdownOpen() and not isOpen then return end
                isOpen = not isOpen
                if isOpen then
                    Dropdown.Visible = true
                    Tween(Dropdown, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Position = UDim2.new(0.5, 0, 0.5, 0) })
                else
                    Dropdown.Visible = false
                    Dropdown.Position = UDim2.new(0.5, 0, 0.3, 0)
                end
            end)

            local Setting = {}
            local selectorFns = {}

            function Setting:Clear(a)
                for _, v in ipairs(ListFrame:GetChildren()) do
                    if v:IsA("Frame") then
                        local shouldClear = a == nil
                            or (type(a) == "string" and v.Title.Text == a)
                            or (type(a) == "table" and isInTable(v.Title.Text, a))
                        if shouldClear then v:Destroy() end
                    end
                end
                if a == nil then
                    Value = nil; selectedValues = {}; selectedOrder = 0
                    DDDesc.Text = "None"; Left.Desc.Text = "None"
                end
            end

            function Setting:AddList(Name)
                local Item = Library:Create("Frame", {
                    Name = "NewList", Parent = ListFrame,
                    BackgroundColor3 = BLACK, BackgroundTransparency = 1,
                    BorderSizePixel = 0, LayoutOrder = 0,
                    Size = UDim2.new(1, 0, 0, 25),
                    ZIndex = 500, Selectable = false
                })
                MakeCorner(Item, UDim.new(0, 2))

                local ItemTitle = Library:Create("TextLabel", {
                    Name = "Title", Parent = Item,
                    AnchorPoint = ANCHOR_CENTER,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0, LayoutOrder = -1,
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    Size = UDim2.new(1, -15, 1, 0),
                    ZIndex = 500, Selectable = false,
                    Font = Enum.Font.GothamSemibold, RichText = true,
                    Text = tostring(Name),
                    TextColor3 = WHITE, TextSize = 11,
                    TextStrokeTransparency = 0.7,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                MakeGradient(ItemTitle, GRAD_WHITE)

                local function OnValue(val)
                    ItemTitle.TextColor3 = val and PINK or WHITE
                    Tween(Item, TI_02_LIN_OUT, { BackgroundTransparency = val and 0.85 or 1 })
                end

                local ItemClick = Library:MakeButton(ItemTitle)

                local function OnSelected()
                    if IsMulti then
                        if selectedValues[Name] then
                            selectedValues[Name] = nil
                            Item.LayoutOrder = 0
                            OnValue(false)
                        else
                            selectedOrder -= 1
                            selectedValues[Name] = selectedOrder
                            Item.LayoutOrder = selectedOrder
                            OnValue(true)
                        end
                        local sel = {}
                        for i in selectedValues do table.insert(sel, i) end
                        if #sel > 0 then
                            table.sort(sel)
                            Value = sel
                            Settext()
                        else
                            DDDesc.Text = "N/A"; Left.Desc.Text = "N/A"
                        end
                        pcall(Callback, sel)
                    else
                        for _, v in ListFrame:GetChildren() do
                            if v:IsA("Frame") and v.Name == 'NewList' then
                                v.Title.TextColor3 = WHITE
                                Tween(v, TI_02_LIN_OUT, { BackgroundTransparency = 1 })
                            end
                        end
                        OnValue(true)
                        Value = Name
                        Settext()
                        pcall(Callback, Value)
                    end
                end

                task.defer(function()
                    if IsMulti then
                        if isInTable(Name, Value) then
                            selectedOrder -= 1
                            selectedValues[Name] = selectedOrder
                            Item.LayoutOrder = selectedOrder
                            OnValue(true)
                            local sel = {}
                            for i in selectedValues do table.insert(sel, i) end
                            if #sel > 0 then table.sort(sel); Settext()
                            else DDDesc.Text = "N/A"; Left.Desc.Text = "N/A" end
                            pcall(Callback, sel)
                        end
                    else
                        if Name == Value then
                            OnValue(true); Settext(); pcall(Callback, Value)
                        end
                    end
                end)

                ItemClick.MouseButton1Click:Connect(OnSelected)
                selectorFns[tostring(Name)] = OnSelected
            end

            SearchBox.Changed:Connect(function()
                local q = string.lower(SearchBox.Text)
                for _, v in ListFrame:GetChildren() do
                    if v:IsA("Frame") and v.Name == 'NewList' then
                        v.Visible = string.find(string.lower(v.Title.Text), q, 1, true) ~= nil
                    end
                end
            end)

            for _, name in ipairs(List) do
                Setting:AddList(name)
            end

            if Args.Flag then
                Window.Flags[Args.Flag] = {
                    Type = "Dropdown",
                    GetValue = function() return Value end,
                    SetValue = function(v)
                        Setting:Clear()
                        if type(v) == "table" then
                            for _, n in ipairs(v) do
                                if selectorFns[tostring(n)] then selectorFns[tostring(n)]() end
                            end
                        else
                            if selectorFns[tostring(v)] then selectorFns[tostring(v)]() end
                        end
                    end
                }
            end

            return Setting
        end

        function Page:Banner(Assets)
            local Banner = Library:Create("ImageLabel", {
                Name = "NewBanner", Parent = PageScrolling,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 235),
                Image = Library:Asset(Assets),
                ScaleType = Enum.ScaleType.Crop
            })
            MakeCorner(Banner)
            return Banner
        end

