        function Page:CheckboxList(Args)
            local List     = Args.List
            local Value    = Args.Value or {}
            local Callback = Args.Callback or function() end

            if Args.Title then
                Page:Section(Args.Title)
            end

            local Container = Library:Create("Frame", {
                Name = "CheckboxList", Parent = PageScrolling,
                BackgroundColor3 = DARK3, BorderSizePixel = 0,
                AutomaticSize = Enum.AutomaticSize.Y,
                Size = UDim2.new(1, 0, 0, 0)
            })
            MakeCorner(Container)
            MakeStroke(Container)
            Library:Create("UIListLayout", {
                Parent = Container,
                Padding = UDim.new(0, 2),
                SortOrder = Enum.SortOrder.LayoutOrder
            })
            Library:Create("UIPadding", {
                Parent = Container,
                PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 6),
                PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4)
            })

            local Selected = {}
            for _, v in ipairs(Value) do Selected[v] = true end

            local Setting = {}
            local refreshFns = {}

            for _, name in ipairs(List) do
                local Row = Library:Create("Frame", {
                    Name = "Row", Parent = Container,
                    BackgroundColor3 = DARK4, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 0, 30)
                })
                MakeCorner(Row, UDim.new(0, 5))
                Library:Create("UIPadding", { Parent = Row, PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8) })
                Library:Create("UIListLayout", {
                    Parent = Row,
                    Padding = UDim.new(0, 10),
                    FillDirection = Enum.FillDirection.Horizontal,
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    VerticalAlignment = Enum.VerticalAlignment.Center
                })

                local Box = Library:Create("Frame", {
                    Name = "Box", Parent = Row,
                    BackgroundColor3 = DARK1, BorderSizePixel = 0,
                    LayoutOrder = -1,
                    Size = UDim2.new(0, 18, 0, 18)
                })
                MakeCorner(Box, UDim.new(0, 5))
                local BoxStroke = MakeStroke(Box, STROKE2, 1)

                local Highlight = Library:Create("Frame", {
                    Name = "Highlight", Parent = Box,
                    AnchorPoint = ANCHOR_CENTER,
                    BackgroundColor3 = PINK, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    Size = UDim2.new(1, 0, 1, 0)
                })
                MakeCorner(Highlight, UDim.new(0, 5))
                MakeGradient(Highlight, GRAD_DARK)

                local Check = Library:Create("ImageLabel", {
                    Parent = Highlight,
                    AnchorPoint = ANCHOR_CENTER,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    Size = UDim2.new(0.65, 0, 0.65, 0),
                    Image = "rbxassetid://86682186031062",
                    ImageTransparency = 1
                })

                local NameLabel = Library:Create("TextLabel", {
                    Name = "Name", Parent = Row,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, -28, 1, 0),
                    Font = Enum.Font.GothamMedium, RichText = true,
                    Text = tostring(name),
                    TextColor3 = WHITE, TextSize = 12,
                    TextStrokeTransparency = 0.7,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                local function Refresh(animated)
                    local on = Selected[name] == true
                    if animated then
                        Tween(Highlight, TI_03_EXP_OUT, { BackgroundTransparency = on and 0 or 1 })
                        Tween(Check,     TI_03_EXP_OUT, { ImageTransparency = on and 0 or 1 })
                        Tween(NameLabel, TI_02_EXP_OUT, { TextColor3 = on and PINK or WHITE })
                        Tween(BoxStroke, TI_02_EXP_OUT, { Thickness = on and 0 or 1 })
                        Tween(Row,       TI_02_EXP_OUT, { BackgroundTransparency = on and 0.9 or 1 })
                    else
                        Highlight.BackgroundTransparency = on and 0 or 1
                        Check.ImageTransparency = on and 0 or 1
                        NameLabel.TextColor3 = on and PINK or WHITE
                        BoxStroke.Thickness = on and 0 or 1
                        Row.BackgroundTransparency = on and 0.9 or 1
                    end
                end

                Refresh(false)
                refreshFns[name] = Refresh

                local RowClick = Library:MakeButton(Row)
                RowClick.MouseButton1Click:Connect(function()
                    if Library:IsDropdownOpen() then return end
                    Selected[name] = not Selected[name]
                    if not Selected[name] then Selected[name] = nil end
                    Refresh(true)
                    local sel = {}
                    for _, n in ipairs(List) do
                        if Selected[n] then table.insert(sel, n) end
                    end
                    Callback(sel)
                end)

                Setting[name] = Row
            end

            if Args.Flag then
                Window.Flags[Args.Flag] = {
                    Type = "CheckboxList",
                    GetValue = function()
                        local sel = {}
                        for _, n in ipairs(List) do
                            if Selected[n] then table.insert(sel, n) end
                        end
                        return sel
                    end,
                    SetValue = function(v)
                        for _, n in ipairs(List) do Selected[n] = nil end
                        for _, n in ipairs(v) do Selected[n] = true end
                        for n, fn in pairs(refreshFns) do fn(true) end
                        local sel = {}
                        for _, n in ipairs(List) do
                            if Selected[n] then table.insert(sel, n) end
                        end
                        Callback(sel)
                    end
                }
            end

            return Setting
        end

        function Page:SubTabs(Args)
            local TabsList = Args.Tabs or {}

            local Container = Library:Create("Frame", {
                Name = "SubTabs", Parent = PageScrolling,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 260)
            })

            local Nav = Library:Create("Frame", {
                Name = "Nav", Parent = Container,
                BackgroundColor3 = DARK3, BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 30)
            })
            MakeCorner(Nav, UDim.new(0, 6))
            MakeStroke(Nav)
            Library:Create("UIListLayout", {
                Parent = Nav,
                Padding = UDim.new(0, 2),
                FillDirection = Enum.FillDirection.Horizontal,
                SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Center,
                HorizontalAlignment = Enum.HorizontalAlignment.Center
            })
            Library:Create("UIPadding", { Parent = Nav, PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4) })

            local Body = Library:Create("Frame", {
                Name = "Body", Parent = Container,
                BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 0, 0, 36),
                Size = UDim2.new(1, 0, 1, -36)
            })

            local SubPageService = Library:Create("UIPageLayout", {
                Parent = Body,
                EasingStyle = Enum.EasingStyle.Exponential,
                TweenTime = 0.35,
                GamepadInputEnabled = false,
                ScrollWheelInputEnabled = false,
                TouchInputEnabled = false
            })

            local SubTabsAPI = {}
            local navButtons = {}
            local firstPanel = nil

            for i, tabDef in ipairs(TabsList) do
                local TabName = tabDef.Title or ("Tab " .. i)

                local NavBtn = Library:Create("Frame", {
                    Name = "NavBtn", Parent = Nav,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = UDim2.new(0, 0, 1, -6)
                })
                MakeCorner(NavBtn, UDim.new(0, 5))

                local NavLabel = Library:Create("TextLabel", {
                    Name = "Title", Parent = NavBtn,
                    AnchorPoint = ANCHOR_CENTER,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    Size = UDim2.new(1, 0, 1, 0),
                    AutomaticSize = Enum.AutomaticSize.X,
                    Font = Enum.Font.GothamSemibold, RichText = true,
                    Text = TabName,
                    TextColor3 = i == 1 and PINK or WHITE,
                    TextSize = 12,
                    TextStrokeTransparency = 0.7
                })
                NavBtn.Size = UDim2.new(0, NavLabel.TextBounds.X + 24, 1, -6)

                local Panel = Library:Create("ScrollingFrame", {
                    Name = "Panel", Parent = Body,
                    Active = true,
                    BackgroundColor3 = WHITE, BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = UDIM2_FILL,
                    AutomaticCanvasSize = Enum.AutomaticSize.None,
                    CanvasPosition = Vector2.new(0, 0),
                    ScrollBarImageColor3 = STROKE3,
                    ScrollBarThickness = 2,
                    ScrollingDirection = Enum.ScrollingDirection.Y
                })
                local PanelLayout = Library:Create("UIListLayout", {
                    Parent = Panel,
                    Padding = UDim.new(0, 5),
                    SortOrder = Enum.SortOrder.LayoutOrder
                })
                Library:Create("UIPadding", {
                    Parent = Panel,
                    PaddingRight = UDim.new(0, 8), PaddingBottom = UDim.new(0, 8)
                })
                PanelLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    Panel.CanvasSize = UDim2.new(0, 0, 0, PanelLayout.AbsoluteContentSize.Y + 10)
                end)

                if i == 1 then firstPanel = Panel end

                local SubPage = {}

                function SubPage:Section(Text) return Page.Section(setmetatable({}, {__index = {Section = nil}}), Text) end

                local function buildPageFns(scrollParent)
                    local proxy = setmetatable({}, { __index = Page })
                    return proxy
                end

                local NavClick = Library:MakeButton(NavBtn)
                NavClick.MouseButton1Click:Connect(function()
                    for _, b in navButtons do
                        Tween(b.Label, TI_02_EXP_OUT, { TextColor3 = WHITE })
                    end
                    Tween(NavLabel, TI_02_EXP_OUT, { TextColor3 = PINK })
                    SubPageService:JumpTo(Panel)
                end)

                table.insert(navButtons, { Btn = NavBtn, Label = NavLabel, Panel = Panel })

                if tabDef.Build then
                    local originalParent = PageScrolling
                    local fakePage = setmetatable({}, { __index = Page })
                    tabDef.Build(fakePage, Panel)
                end

                SubTabsAPI[i] = { Panel = Panel, NavBtn = NavBtn }
            end

            if firstPanel then SubPageService:JumpTo(firstPanel) end

            return SubTabsAPI
        end

        TabClick.MouseButton1Click:Connect(OnChangePage)
        return Page
    end

