local Library = {}

local Players = game:GetService('Players')
local RunService = game:GetService('RunService')
local UserInputService = game:GetService('UserInputService')
local TweenService = game:GetService('TweenService')
local CoreGui = game:GetService('CoreGui')
local HttpService = game:GetService('HttpService')

local IconsLoaded, Icons = pcall(function()
    return loadstring(game:HttpGetAsync("https://raw.githubusercontent.com/Footagesus/Icons/main/Main-v2.lua"))()
end)
if IconsLoaded and Icons then
    Icons.SetIconsType("lucide")
else
    Icons = nil
end

function Library:GetIcon(name)
    if Icons and type(name) == "string" and not name:find("rbxassetid://") and not tonumber(name) then
        local ok, result = pcall(function() return Icons.GetIcon(name) end)
        if ok and result then return result end
    end
    return Library:Asset(name)
end

local Mobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

local PINK  = Color3.fromRGB(255, 0, 127)
local WHITE = Color3.fromRGB(255, 255, 255)
local BLACK = Color3.fromRGB(0, 0, 0)
local DARK1 = Color3.fromRGB(10, 10, 10)
local DARK2 = Color3.fromRGB(11, 11, 11)
local DARK3 = Color3.fromRGB(15, 15, 15)
local DARK4 = Color3.fromRGB(18, 18, 18)
local STROKE = Color3.fromRGB(25, 25, 25)
local STROKE2 = Color3.fromRGB(30, 30, 30)
local STROKE3 = Color3.fromRGB(75, 0, 38)
local GRAY1 = Color3.fromRGB(163, 163, 163)
local GRAY2 = Color3.fromRGB(100, 100, 100)
local GRAY3 = Color3.fromRGB(56, 56, 56)

local GRAD_WHITE = ColorSequence.new{
    ColorSequenceKeypoint.new(0, WHITE),
    ColorSequenceKeypoint.new(0.749568, GRAY1),
    ColorSequenceKeypoint.new(1, GRAY2)
}

local GRAD_DARK = ColorSequence.new{
    ColorSequenceKeypoint.new(0, WHITE),
    ColorSequenceKeypoint.new(1, GRAY3)
}

local GRAD_SLIDER = ColorSequence.new{
    ColorSequenceKeypoint.new(0, WHITE),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(47, 47, 47))
}

local UDIM2_FILL = UDim2.new(1, 0, 1, 0)
local UDIM2_ZERO = UDim2.new(0, 0, 0, 0)
local ANCHOR_CENTER = Vector2.new(0.5, 0.5)

local TWEEN_CACHE = {}
local function Tween(instance, tweenInfo, goal)
    local key = tostring(instance) .. tostring(tweenInfo)
    local t = TWEEN_CACHE[key]
    if t then t:Cancel() end
    t = TweenService:Create(instance, tweenInfo, goal)
    TWEEN_CACHE[key] = t
    t:Play()
    return t
end

local TI_05_EXP_OUT  = TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
local TI_03_EXP_OUT  = TweenInfo.new(0.3, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
local TI_02_EXP_OUT  = TweenInfo.new(0.2, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
local TI_03_BACK_OUT = TweenInfo.new(0.3, Enum.EasingStyle.Back,        Enum.EasingDirection.Out)
local TI_01_LIN_OUT  = TweenInfo.new(0.1, Enum.EasingStyle.Linear,      Enum.EasingDirection.Out)
local TI_02_LIN_OUT  = TweenInfo.new(0.2, Enum.EasingStyle.Linear,      Enum.EasingDirection.Out)
local TI_025_EXP_OUT = TweenInfo.new(0.25,Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
local TI_03_DRAG     = TweenInfo.new(0.3)
local TI_25_BACK_OUT = TweenInfo.new(2.5, Enum.EasingStyle.Back,        Enum.EasingDirection.Out)

function Library:Parent()
    if not RunService:IsStudio() then
        return (gethui and gethui()) or CoreGui
    end
    return PlayerGui
end

function Library:Create(Class, Props)
    local inst = Instance.new(Class)
    for k, v in Props do inst[k] = v end
    return inst
end

function Library:Draggable(frame)
    local dragging, dragInput, dragStart, startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Tween(frame, TI_03_DRAG, {
                Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            })
        end
    end)
end

function Library:MakeButton(Parent)
    return Library:Create("TextButton", {
        Name = "Click", Parent = Parent,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderColor3 = BLACK, BorderSizePixel = 0,
        Size = UDIM2_FILL,
        Font = Enum.Font.SourceSans, Text = "",
        TextColor3 = BLACK, TextSize = 14,
        ZIndex = Parent.ZIndex + 3
    })
end

Library.Button = Library.MakeButton

function Library.Effect(clickArea, parent)
    parent.ClipsDescendants = true
    local mouse = LocalPlayer:GetMouse()
    local rx = mouse.X - clickArea.AbsolutePosition.X
    local ry = mouse.Y - clickArea.AbsolutePosition.Y
    if rx < 0 or ry < 0 or rx > clickArea.AbsoluteSize.X or ry > clickArea.AbsoluteSize.Y then return end

    local circle = Library:Create("Frame", {
        Parent = parent,
        BackgroundColor3 = WHITE, BackgroundTransparency = 0.75,
        BorderSizePixel = 0, AnchorPoint = ANCHOR_CENTER,
        Position = UDim2.new(0, rx, 0, ry),
        Size = UDIM2_ZERO, ZIndex = parent.ZIndex
    })
    Library:Create("UICorner", { Parent = circle, CornerRadius = UDim.new(1, 0) })

    local sz = clickArea.AbsoluteSize.X * 1.5
    local t = TweenService:Create(circle, TI_25_BACK_OUT, {
        Size = UDim2.new(0, sz, 0, sz), BackgroundTransparency = 1
    })
    t.Completed:Once(function() circle:Destroy() end)
    t:Play()
end

function Library:Asset(rbx)
    if type(rbx) == 'number' then return "rbxassetid://" .. rbx end
    if type(rbx) == 'string' and rbx:find('rbxassetid://') then return rbx end
    return rbx
end

local function MakeGradient(parent, colorSeq, rotation)
    Library:Create("UIGradient", { Parent = parent, Color = colorSeq, Rotation = rotation or 90 })
end

local function MakeCorner(parent, radius)
    Library:Create("UICorner", { Parent = parent, CornerRadius = radius or UDim.new(0, 3) })
end

local function MakeStroke(parent, color, thickness)
    return Library:Create("UIStroke", { Parent = parent, Color = color or STROKE, Thickness = thickness or 0.5 })
end

function Library:Tooltip(target, text)
    local gui = Library:Parent()
    local TipGui = Library:Create("ScreenGui", {
        Name = "JustinTooltip", Parent = gui,
        ZIndexBehavior = Enum.ZIndexBehavior.Global,
        IgnoreGuiInset = true, DisplayOrder = 999
    })

    local Tip = Library:Create("Frame", {
        Name = "Tip", Parent = TipGui,
        BackgroundColor3 = DARK4, BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.X,
        Size = UDim2.new(0, 0, 0, 24),
        Visible = false, ZIndex = 1000
    })
    MakeCorner(Tip, UDim.new(0, 5))
    MakeStroke(Tip, STROKE2, 1)

    Library:Create("UIPadding", {
        Parent = Tip,
        PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8),
        PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4)
    })

    local Label = Library:Create("TextLabel", {
        Name = "Label", Parent = Tip,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.X,
        Size = UDim2.new(0, 0, 1, 0),
        Font = Enum.Font.GothamMedium, RichText = true,
        Text = text, TextColor3 = WHITE, TextSize = 11,
        TextTransparency = 0.1, ZIndex = 1001
    })

    local function Show()
        local mouse = UserInputService:GetMouseLocation()
        Tip.Position = UDim2.new(0, mouse.X + 14, 0, mouse.Y - 26)
        Tip.Visible = true
        Tip.BackgroundTransparency = 1
        Label.TextTransparency = 1
        Tween(Tip, TI_02_EXP_OUT, { BackgroundTransparency = 0 })
        Tween(Label, TI_02_EXP_OUT, { TextTransparency = 0.1 })
    end

    local function Hide()
        Tween(Tip, TI_02_EXP_OUT, { BackgroundTransparency = 1 })
        Tween(Label, TI_02_EXP_OUT, { TextTransparency = 1 })
        task.delay(0.2, function() Tip.Visible = false end)
    end

    target.MouseEnter:Connect(Show)
    target.MouseLeave:Connect(Hide)
    target.MouseMoved:Connect(function()
        local mouse = UserInputService:GetMouseLocation()
        Tip.Position = UDim2.new(0, mouse.X + 14, 0, mouse.Y - 26)
    end)

    return Tip
end

function Library:Notify(Args)
    Args = Args or {}
    local Title    = Args.Title or "Notification"
    local Desc     = Args.Desc or ""
    local Duration = Args.Duration or 4
    local Icon     = Args.Icon

    local gui = Library:Parent()
    local ToastGui = nil
    for _, v in gui:GetChildren() do
        if v.Name == "JustinToasts" then ToastGui = v break end
    end
    if not ToastGui then
        ToastGui = Library:Create("ScreenGui", {
            Name = "JustinToasts", Parent = gui,
            ZIndexBehavior = Enum.ZIndexBehavior.Global,
            IgnoreGuiInset = true, DisplayOrder = 998
        })
        Library:Create("UIListLayout", {
            Parent = ToastGui,
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
            HorizontalAlignment = Enum.HorizontalAlignment.Right,
            VerticalAlignment = Enum.VerticalAlignment.Bottom
        })
        Library:Create("UIPadding", {
            Parent = ToastGui,
            PaddingRight = UDim.new(0, 16), PaddingBottom = UDim.new(0, 16)
        })
    end

    local Toast = Library:Create("Frame", {
        Name = "Toast", Parent = ToastGui,
        AnchorPoint = Vector2.new(1, 1),
        BackgroundColor3 = DARK3, BorderSizePixel = 0,
        Size = UDim2.new(0, 260, 0, 56),
        Position = UDim2.new(1, 60, 1, 0),
        ZIndex = 1000, ClipsDescendants = true
    })
    MakeCorner(Toast, UDim.new(0, 8))
    MakeStroke(Toast, STROKE3, 1)

    local Bar = Library:Create("Frame", {
        Name = "Bar", Parent = Toast,
        BackgroundColor3 = PINK, BorderSizePixel = 0,
        Size = UDim2.new(0, 3, 1, 0),
        ZIndex = 1001
    })
    MakeGradient(Bar, GRAD_DARK)

    local Content = Library:Create("Frame", {
        Name = "Content", Parent = Toast,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 14, 0, 0),
        Size = UDim2.new(1, -24, 1, 0),
        ZIndex = 1001
    })
    Library:Create("UIListLayout", {
        Parent = Content,
        Padding = UDim.new(0, 2),
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Center
    })

    local TitleLabel = Library:Create("TextLabel", {
        Name = "Title", Parent = Content,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 16),
        Font = Enum.Font.GothamBold, RichText = true, Text = Title,
        TextColor3 = PINK, TextSize = 13,
        TextStrokeTransparency = 0.7,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 1002
    })
    MakeGradient(TitleLabel, GRAD_WHITE)

    Library:Create("TextLabel", {
        Name = "Desc", Parent = Content,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 14),
        Font = Enum.Font.GothamMedium, RichText = true, Text = Desc,
        TextColor3 = WHITE, TextSize = 11,
        TextTransparency = 0.4, TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 1002
    })

    Toast.Position = UDim2.new(1, 60, 1, 0)
    Tween(Toast, TI_03_BACK_OUT, { Position = UDim2.new(1, 0, 1, 0) })

    task.delay(Duration, function()
        if not Toast or not Toast.Parent then return end
        Tween(Toast, TI_03_EXP_OUT, { Position = UDim2.new(1, 60, 1, 0) })
        task.delay(0.3, function()
            if Toast then Toast:Destroy() end
        end)
    end)

    return Toast
end

function Library:NewRows(Parent, Title, Desc)
    local hasDesc = Desc and Desc ~= ""
    local rowHeight = hasDesc and 40 or 28

    local Rows = Library:Create("Frame", {
        Name = "Rows", Parent = Parent,
        BackgroundColor3 = DARK3, BorderColor3 = BLACK, BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, rowHeight)
    })
    MakeStroke(Rows)
    MakeCorner(Rows)

    Library:Create("UIListLayout", {
        Parent = Rows,
        Padding = UDim.new(0, 6),
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Center
    })
    Library:Create("UIPadding", {
        Parent = Rows,
        PaddingBottom = UDim.new(0, 6),
        PaddingTop = UDim.new(0, 5)
    })

    local Vectorize = Library:Create("Frame", {
        Name = "Vectorize", Parent = Rows,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderColor3 = BLACK, BorderSizePixel = 0,
        Size = UDIM2_FILL
    })
    Library:Create("UIPadding", {
        Parent = Vectorize,
        PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10)
    })

    local Right = Library:Create("Frame", {
        Name = "Right", Parent = Vectorize,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderColor3 = BLACK, BorderSizePixel = 0,
        Size = UDIM2_FILL
    })
    Library:Create("UIListLayout", {
        Parent = Right,
        Padding = UDim.new(0, 8),
        FillDirection = Enum.FillDirection.Horizontal,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Center
    })

    local Left = Library:Create("Frame", {
        Name = "Left", Parent = Vectorize,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderColor3 = BLACK, BorderSizePixel = 0,
        Size = UDIM2_FILL
    })

    local Text = Library:Create("Frame", {
        Name = "Text", Parent = Left,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderColor3 = BLACK, BorderSizePixel = 0,
        Size = UDIM2_FILL
    })
    Library:Create("UIListLayout", {
        Parent = Text,
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Center
    })

    local TitleLabel = Library:Create("TextLabel", {
        Name = "Title", Parent = Text,
        AnchorPoint = ANCHOR_CENTER,
        BackgroundColor3 = WHITE, BackgroundTransparency = 1,
        BorderColor3 = BLACK, BorderSizePixel = 0,
        LayoutOrder = -1,
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, 0, 0, 13),
        Font = Enum.Font.GothamSemibold,
        RichText = true, Text = Title,
        TextColor3 = WHITE, TextSize = 12,
        TextStrokeTransparency = 0.7,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    MakeGradient(TitleLabel, GRAD_WHITE)

    if hasDesc then
        Library:Create("TextLabel", {
            Name = "Desc", Parent = Text,
            AnchorPoint = ANCHOR_CENTER,
            BackgroundColor3 = WHITE, BackgroundTransparency = 1,
            BorderColor3 = BLACK, BorderSizePixel = 0,
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.new(1, 0, 0, 10),
            Font = Enum.Font.GothamMedium,
            RichText = true, Text = Desc,
            TextColor3 = WHITE, TextSize = 10,
            TextStrokeTransparency = 0.7, TextTransparency = 0.6,
            TextXAlignment = Enum.TextXAlignment.Left
        })
    else
        Library:Create("TextLabel", {
            Name = "Desc", Parent = Text,
            BackgroundColor3 = WHITE, BackgroundTransparency = 1,
            BorderColor3 = BLACK, BorderSizePixel = 0,
            Size = UDim2.new(0, 0, 0, 0), Visible = false,
            Font = Enum.Font.GothamMedium,
            RichText = true, Text = "",
            TextColor3 = WHITE, TextSize = 10
        })
    end

    return Rows
end

